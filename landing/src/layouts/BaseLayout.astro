---
// Fonts are imported by tokens.css (the single design control panel),
// which global.css pulls in first.
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  /** Search-indexing directive. Omitted on indexable pages; the login page
   *  passes "noindex, nofollow" so auth URLs (with ?status / ?error) stay out
   *  of search results. */
  robots?: string;
  /** Optional page-specific schema.org entity (e.g. SoftwareApplication on the
   *  home page) merged into the site-wide Organization + WebSite JSON-LD graph. */
  jsonLd?: Record<string, unknown>;
}

// REQ-LANDING-003: the landing page carries the canonical external metadata
// for the enterprise positioning. og.png is served from the SPA asset root.
const {
  title = 'Codeflare: The Enterprise Agentic Engine',
  description = 'Not a coding assistant. Codeflare runs governed engineering agents that build, test, review, and operate inside your own estate.',
  canonical = 'https://codeflare.ch/',
  robots,
  jsonLd,
} = Astro.props;

// REQ-LANDING-003: site-wide structured data (schema.org) so search engines and
// LLMs resolve Codeflare to a named Organization + WebSite, with an optional
// page-specific entity grafted on. JSON-LD is a data block (not executed), so it
// is unaffected by the landing's script-src 'self' CSP.
const orgId = 'https://codeflare.ch/#organization';
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': orgId,
      name: 'Codeflare',
      url: 'https://codeflare.ch/',
      logo: 'https://codeflare.ch/icon-512.png',
      description:
        'The enterprise agentic engine: governed engineering agents that build, test, review, and operate inside your own estate.',
      sameAs: ['https://github.com/nikolanovoselec/codeflare'],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://codeflare.ch/#website',
      url: 'https://codeflare.ch/',
      name: 'Codeflare',
      publisher: { '@id': orgId },
    },
    ...(jsonLd ? [jsonLd] : []),
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#0a0a0c" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Codeflare" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://codeflare.ch/og.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Codeflare: the enterprise agentic engine." />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://codeflare.ch/og.png" />
    <meta name="twitter:image:alt" content="Codeflare: the enterprise agentic engine." />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <!-- Page-wide flare-fluid signature: the WebGL canvas is injected here and a
         readability veil sits above it, behind all content (desktop + fine
         pointer only; splash.ts adds html.flare-on once it mounts). -->
    <div class="flare-field" data-flare-fluid aria-hidden="true"></div>
    <slot />
    <script>
      // Hero top-line capability ticker (current word white, queued words stacked upward).
      import '../scripts/hero-kicker';
    </script>
    <script>
      // Hero accent-word scramble (perpetual four-phase idle loop; reduced-motion safe).
      import '../scripts/scramble';
    </script>
    <script>
      // Coding-agent statusline foot: slow context tick + an occasional compaction
      // beat on the hero terminal (reduced-motion safe; the static foot otherwise).
      import '../scripts/agentfoot';
    </script>
    <script>
      // Feature-terminal live prompts: each tile's command line types/deletes a
      // short command in a loop, staggered; one tile just blinks (reduced-motion
      // safe; the static first prompt otherwise).
      import '../scripts/feature-terminals';
    </script>
    <script>
      // Proof-terminal last line (cursor mode): types the final transcript line in
      // when the terminal scrolls into view, then rests on it (reduced-motion safe;
      // the full server-rendered line stands otherwise).
      import '../scripts/type-on-view';
    </script>
    <script>
      // Page-wide flare-fluid signature (WebGL; desktop pointers only, reduced-motion safe).
      import '../scripts/splash';
    </script>
    <script>
      // Proof artifacts (enforcement loop, review board, boundary path, ledger):
      // plays each one's CSS sequence once when it scrolls into view. Content is
      // fully legible without it (static final state); reduced-motion shows the
      // final state instantly.
      import '../scripts/proof';
    </script>
    <script>
      // Orchestration station: ticks each agent's tool-use / token counters and
      // advances its activity line so the "Running N agents" view reads as a live
      // feed. Pauses off-screen and when the tab is hidden (reduced-motion safe;
      // the resolved counters and first activity stand otherwise).
      import '../scripts/orch';
    </script>
    <script>
      // Entrance + nav-chrome wiring: .reveal elements fade up on first view
      // (above-the-fold elements are skipped to avoid an open-page flicker), and
      // the sticky nav gains a depth seam once scrolled. Content is visible by
      // default (no-JS and reduced-motion visitors see everything).
      import '../scripts/reveal';
    </script>
  </body>
</html>
