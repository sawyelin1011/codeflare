{
  "name": "codeflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "cd web-ui && npm ci && npm run build",
    "deploy": "npm run build && wrangler deploy",
    "generate:tutorial-seed": "node scripts/generate-tutorial-seed.mjs",
    "generate:agent-seed": "node scripts/generate-agent-seed.mjs",
    "prebuild": "npm run generate:tutorial-seed && npm run generate:agent-seed",
    "pretest": "npm run generate:tutorial-seed && npm run generate:agent-seed",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts e2e/api/",
    "test:e2e:ui": "vitest run --config vitest.e2e.config.ts e2e/ui/",
    "test:e2e:api": "vitest run --config vitest.e2e.config.ts e2e/api/",
    "test:e2e:ui-desktop": "vitest run --config vitest.e2e.config.ts e2e/ui/",
    "test:e2e:ui-mobile": "E2E_MOBILE=1 vitest run --config vitest.e2e.config.ts e2e/ui/",
    "postinstall": "node scripts/fix-broken-sourcemaps.js",
    "lint": "oxlint src/ e2e/ --deny-warnings",
    "lint:fix": "oxlint src/ e2e/ --fix",
    "knip": "knip"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.1.1",
    "aws4fetch": "^1.0.20",
    "hono": "^4.12.7",
    "zod": "^4.3.6"
  },
  "overrides": {
    "minimatch": ">=10.2.1",
    "glob": ">=11.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.19",
    "@cloudflare/workers-types": "^4.20260310.1",
    "@vitest/coverage-v8": "^3.0.0",
    "fast-check": "^4.6.0",
    "knip": "^5.86.0",
    "oxlint": "^1.55.0",
    "puppeteer": "^24.39.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.72.0"
  }
}
