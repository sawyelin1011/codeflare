{
  "description": "Routes tool calls through context-mode for deterministic context-window reduction. Tier-gated to unlimited (Custom) tier and Pro session mode by R2 preseed filter.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|WebFetch|Grep|Glob|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y context-mode@1.0.111 hook claude-code pretooluse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Read|WebFetch|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y context-mode@1.0.111 hook claude-code posttooluse"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y context-mode@1.0.111 hook claude-code precompact"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y context-mode@1.0.111 hook claude-code sessionstart"
          }
        ]
      }
    ]
  }
}
