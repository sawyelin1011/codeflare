# graphify (canonical pattern set lives in preseed/agents/claude/skills/graphify/SKILL.md note 3)
# Regenerable build outputs - large, no value cross-machine:
graphify-out/cache/
graphify-out/.cache/
graphify-out/.chunks/
graphify-out/manifest.json
graphify-out/obsidian/
# Working-tree intermediates - cleaned by the build's Step 9,
# gitignored as the safety net for runs interrupted before cleanup:
.graphify_ast.json
.graphify_semantic.json
.graphify_semantic_new.json
.graphify_extract.json
.graphify_detect.json
.graphify_analysis.json
.graphify_cached.json
.graphify_uncached.txt
.graphify_chunk_*.txt
.graphify_old.json
.graphify_community_label_worklist.json
.graphify_community_label_batches/
# Per-machine markers - absolute path / root-level transient labels:
.graphify_root
/.graphify_labels.json
# Dated snapshot output dirs the build writes - never commit; only the flat
# graphify-out/ files (graph.json, GRAPH_REPORT.md, graph.html, callflow.html,
# .graphify_labels.json) are durable:
graphify-out/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/

# Phase 7a source-anchor verifier output (regenerated every /sdd init run)
.verify-anchors.json

# Raw ingest material for graphify (sourced from private repos)
raw/
